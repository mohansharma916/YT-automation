            "text": "भैया का अच्छा कह रहे ठीक है तू"
        },
        {
            "start": 817.065,
            "end": 820.985,
            "text": "तो यह सही है और जो तबीयत खराब"
        },
        {
            "start": 820.985,
            "end": 823.065,
            "text": "थी वह ठीक है ऐसे पूछते हैं लोग"

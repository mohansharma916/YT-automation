            "start": 793.16504,
            "end": 795.38,
            "text": "भी नहीं नहीं कोई नहीं चली गई फिर"
        },
        {
            "start": 795.38,
            "end": 796.9,
            "text": "अच्छा ऐसा नहीं लगता है कि हमारे घर"
        },
        {
            "start": 796.9,
            "end": 800.58,
            "text": "से कोई जाए सही सही बात है वैसे"
        },
        {
            "start": 802.18,
            "end": 804.5,
            "text": "क्योंकि इतनी दूर पर तो है नहीं है"
        },
        {
            "start": 810.505,
            "end": 812.425,
            "text": "कल परसों भैया का भी phone आया था"
        },
        {

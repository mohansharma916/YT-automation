            "text": "interact किए तो यहां पुछ लेंगे वगैरह तो"
        },
        {
            "start": 826.08,
            "end": 828.16003,
            "text": "जब तबियत तेरी खराब थी वो ठीक है"
        },
        {
            "start": 828.16003,
            "end": 831.52,
            "text": "तबियत वो भी हां यह आ रहा है"
        },
        {
            "start": 831.52,
            "end": 838.16003,
            "text": "मैं ठीक है आ जाता है ऐसा नहीं"
        },
        {
            "start": 838.16003,
            "end": 849.92505,
            "text": "है अभी तुझे पूछने के लिए है खाना"
        },
        {
            "start": 849.92505,

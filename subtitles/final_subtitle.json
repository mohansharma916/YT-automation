{
    "segments": [
        {
            "start": 0.0,
            "end": 5.0,
            "text": " पेट मेरा ओपरिशन के बाद से फूला लिमिट से ज़ादा"
        },
        {
            "start": 5.0,
            "end": 8.0,
            "text": " क्या इसमें ही बढ़ दिया है क्या वो मास जंग"
        },
        {
            "start": 8.0,
            "end": 13.0,
            "text": " ठीक है ज़ादा"
        },
        {
            "start": 8.0,
            "end": 10.0,
            "text": " अब वो अजीच आउराह"
        },
        {
            "start": 10.0,
            "end": 13.0,
            "text": " कुछ नही है जासे हर्कम पंचा गुया है घर में"
        },
        {
            "start": 13.0,
            "end": 14.0,
            "text": " आ गया होै भावा?"
        },
        {
            "start": 14.0,
            "end": 18.0,
            "text": " नही वो बारे बजे की आ गया, बारे बजे आने के बाद मैं नाही भी नहीं थी जब तक"
        },
        {
            "start": 18.0,
            "end": 20.0,
            "text": " धार भाव हो कर रही थी"
        },
        {
            "start": 80.0,
            "end": 86.0,
            "text": " पड़ाएगा। यह भी चोटी था और इसका न मज़ाक न तुड़ाएगा न अशी चीजो पे"
        },
        {
            "start": 86.0,
            "end": 90.0,
            "text": " प्रिस करेगा नी प्यार से बोला इसका जब से"
        },
        {
            "start": 90.0,
            "end": 96.0,
            "text": " इसका दिमाग मेरे पर गई आई"
        },
        {
            "start": 96.0,
            "end": 101.0,
            "text": " उदम जादार पेट पर सोरों म्मा की पर"
        },
        {
            "start": 101.0,
            "end": 104.0,
            "text": " ओई ओई ओई ड्रामे मत करे"
        },
        {
            "start": 134.0,
            "end": 138.0,
            "text": " टाइट करना नहीं हुआ यह तमारा कमजोरी करना हुआ फिर"
        },
        {
            "start": 138.0,
            "end": 142.0,
            "text": " या करो यार बागो पेटी जम नहीं हो फिर देगा"
        },
        {
            "start": 142.0,
            "end": 147.0,
            "text": " पेट मेरा ओपरिशन के बाद से फूला लिमिट से ज़ादा"
        },
        {
            "start": 147.0,
            "end": 150.0,
            "text": " क्या इसमें ही बढ़ दिया है क्या वो मास जंग"
        },
        {
            "start": 150.0,
            "end": 155.0,
            "text": " ठीक है ज़ादा"
        }
    ]
}